DATABASE_URL=your-neon-connection-string-here
GEMINI_API_KEY=your-gemini-api-key-here
JWT_SECRET=your-jwt-secret-here

# Exact origin your frontend is served from. Required for cookies to work —
# CORS + credentials cannot use a wildcard origin.
FRONTEND_ORIGIN=http://localhost:5173

# Set to true once your app is served over HTTPS in production.
# Must stay false for local http://localhost development.
COOKIE_SECURE=false
